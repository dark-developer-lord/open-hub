# ──────────────────────────────────────────────────────────────────────────────
# AI Provider API Keys — copy this file to .env and fill in the keys you need
# ──────────────────────────────────────────────────────────────────────────────

# ── Anthropic (Claude) ────────────────────────────────────────────────────────
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ── OpenAI (GPT, o-series) ────────────────────────────────────────────────────
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── Google (Gemini) ───────────────────────────────────────────────────────────
# https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# ── Groq (Llama, Mixtral — ultra-fast inference) ─────────────────────────────
# https://console.groq.com/keys
GROQ_API_KEY=

# ── Mistral AI ────────────────────────────────────────────────────────────────
# https://console.mistral.ai/api-keys
MISTRAL_API_KEY=

# ── xAI (Grok) ───────────────────────────────────────────────────────────────
# https://console.x.ai
XAI_API_KEY=

# ── Perplexity (Sonar — web-search enabled models) ───────────────────────────
# https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=

# ── DeepSeek ─────────────────────────────────────────────────────────────────
# https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# ── Together AI (500+ open-source models) ────────────────────────────────────
# https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=

# ── Fireworks AI ─────────────────────────────────────────────────────────────
# https://fireworks.ai/account/api-keys
FIREWORKS_API_KEY=

# ── Cerebras (fast hardware inference) ───────────────────────────────────────
# https://cloud.cerebras.ai
CEREBRAS_API_KEY=

# ── Cohere (Command models) ───────────────────────────────────────────────────
# https://dashboard.cohere.com/api-keys
COHERE_API_KEY=

# ── Novita AI (cheap open-source inference) ──────────────────────────────────
# https://novita.ai/settings/key-management
NOVITA_API_KEY=

# ── Alibaba Qwen / DashScope ─────────────────────────────────────────────────
# https://dashscope.console.aliyun.com/apiKey
# Models: Qwen3, Qwen2.5, QwQ, Qwen2.5-Coder, Qwen2.5-VL, etc.
DASHSCOPE_API_KEY=
# (QWEN_API_KEY is accepted as alias)

# ── Ollama (local models — no key needed) ────────────────────────────────────
# Install: https://ollama.com  |  Pull a model: ollama pull llama3.3
OLLAMA_HOST=http://localhost:11434

# ── Azure OpenAI ─────────────────────────────────────────────────────────────
# https://portal.azure.com → Azure OpenAI resource → Keys and Endpoint
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com
AZURE_OPENAI_API_VERSION=2024-10-21

# ──────────────────────────────────────────────────────────────────────────────
# Default provider and model
# ──────────────────────────────────────────────────────────────────────────────
DEFAULT_PROVIDER=anthropic
DEFAULT_MODEL=claude-opus-4-5

# ── Agent behavior ────────────────────────────────────────────────────────────
# Max iterations for goal-driven loops (--goal flag). Raise for long autonomous tasks.
MAX_GOAL_ITERATIONS=200
# Max output tokens per model turn. Modern models support 32k–128k. Raise for longer responses.
MAX_TOKENS_PER_TURN=32768
# How often (in turns) to check goal completion
GOAL_CHECK_INTERVAL=3
# Permission mode: bypassPermissions (default) | default | acceptEdits | plan
AGENT_PERMISSION_MODE=bypassPermissions

# Sessions storage path (defaults to ~/.agent-cli/sessions)
SESSIONS_DIR=

# ══════════════════════════════════════════════════════════════════════════════
# DYNAMIC CUSTOM PROVIDERS — add any OpenAI-compatible API without code changes
# ══════════════════════════════════════════════════════════════════════════════
# Pattern: PROVIDER_<ID>_BASE_URL   (required — the /v1 endpoint)
#          PROVIDER_<ID>_API_KEY    (optional)
#          PROVIDER_<ID>_NAME       (optional display name, defaults to ID)
#          PROVIDER_<ID>_MODELS     (optional, comma-separated model IDs)
#          PROVIDER_<ID>_ALLOW_EMPTY_KEY  (optional, "true" for local servers)
#
# Examples:
#
# # LM Studio (local)
# PROVIDER_LMSTUDIO_BASE_URL=http://localhost:1234/v1
# PROVIDER_LMSTUDIO_NAME=LM Studio
# PROVIDER_LMSTUDIO_MODELS=your-model-name
#
# # vLLM server
# PROVIDER_VLLM_BASE_URL=http://localhost:8000/v1
# PROVIDER_VLLM_NAME=vLLM
# PROVIDER_VLLM_MODELS=Qwen/Qwen3-8B
#
# # OpenRouter (100+ models via one key)
# PROVIDER_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# PROVIDER_OPENROUTER_API_KEY=sk-or-...
# PROVIDER_OPENROUTER_NAME=OpenRouter
# PROVIDER_OPENROUTER_MODELS=meta-llama/llama-4-scout,google/gemini-2.5-flash
#
# # Any custom enterprise or self-hosted endpoint
# PROVIDER_MYCOMPANY_BASE_URL=https://api.mycompany.com/v1
# PROVIDER_MYCOMPANY_API_KEY=sk-...
# PROVIDER_MYCOMPANY_NAME=MyCompany LLM
# PROVIDER_MYCOMPANY_MODELS=gpt-company-large,gpt-company-small

# ══════════════════════════════════════════════════════════════════════════════
# DYNAMIC MCP SERVERS — auto-connect without editing mcp.json
# ══════════════════════════════════════════════════════════════════════════════
# Pattern: MCP_SERVER_<NAME>_TYPE     (stdio|http|sse)
#          MCP_SERVER_<NAME>_COMMAND  (for stdio, e.g. npx)
#          MCP_SERVER_<NAME>_ARGS     (comma-separated args)
#          MCP_SERVER_<NAME>_URL      (for http/sse)
#
# Examples:
#
# MCP_SERVER_MEMORY_TYPE=stdio
# MCP_SERVER_MEMORY_COMMAND=npx
# MCP_SERVER_MEMORY_ARGS=-y,@modelcontextprotocol/server-memory
#
# MCP_SERVER_MYSERVICE_TYPE=http
# MCP_SERVER_MYSERVICE_URL=http://localhost:9000/mcp
